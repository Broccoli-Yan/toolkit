{
  "manifest_version": 3,
  "name": "AI 选中问答",
  "version": "0.1.0",
  "description": "选中网页内容，一键向 AI 提问",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": [],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI 选中问答"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}